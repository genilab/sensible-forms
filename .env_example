##
## EXAMPLE FOR .env file
## Rename this file to .env and complete the fields
##

VITE_API_BASE_URL=http://localhost:8000

OPENAI_API_KEY = {insert OpenAI-compatible API key}
OPENAI_BASE_URL = {insert API server URL}
OPENAI_MODEL = {insert desired model name}

# If you want to use a Gemini or Google API key,
#   uncomment the appropriate line below and
#   comment out the OPENAI_API_KEY line above
# GOOGLE_API_KEY={insert Google API key}
# GEMINI_API_KEY={insert Gemini/Google API key}