[run]
# Keep all backend subsystems included in coverage measurement.
branch = True
source =
	backend/app

# Omit boilerplate and non-production code.
omit =
	*/__pycache__/*
	*/__init__.py
	backend/app/core/*
	backend/app/tests/*
	backend/app/infrastructure/llm/mock.py

[report]
show_missing = True
# Hide files that are already at 100% to reduce noise.
skip_covered = True
precision = 0
